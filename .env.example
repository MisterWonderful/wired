# Wired — Environment Variables
# Copy this to .env.local and fill in your values

# Database (SQLite — leave as-is for file-based storage)
DATABASE_URL=file:./data/wired.db

# Server
PORT=3000
NODE_ENV=development

# AI Configuration (optional — without these, AI features use mock data)
# AI_API_KEY=sk-your-openai-key-here
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# GitHub (optional — enables GitHub repo browsing and metadata fetching)
# GITHUB_TOKEN=ghp_your_github_token_here

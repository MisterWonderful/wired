{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wired",
  "version": "0.1.0",
  "identifier": "ai.wired.app",
  "build": {
    "frontendDist": "../web/out",
    "devUrl": "http://localhost:3008",
    "beforeDevCommand": "pnpm --filter @wired/web dev",
    "beforeBuildCommand": "pnpm --filter @wired/web build"
  },
  "app": {
    "windows": [
      {
        "title": "Wired",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "fs": {
      "scope": ["$HOME/**", "$APPDATA/**", "$LOCALAPPDATA/**"]
    },
    "dialog": {
      "all": true
    },
    "shell": {
      "open": true
    }
  }
}

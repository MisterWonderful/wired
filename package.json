{
  "name": "wired",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "corepack pnpm --parallel dev",
    "build": "corepack pnpm -r build",
    "lint": "corepack pnpm -r lint",
    "typecheck": "corepack pnpm -r typecheck",
    "test": "corepack pnpm -r test",
    "db:generate": "corepack pnpm --filter @wired/db generate",
    "db:migrate": "corepack pnpm --filter @wired/db migrate",
    "db:push": "corepack pnpm --filter @wired/db push",
    "seed": "tsx scripts/seed-demo-data.ts"
  },
  "devDependencies": {
    "@wired/ai": "workspace:*",
    "@wired/core": "workspace:*",
    "@wired/db": "workspace:*",
    "@wired/git": "workspace:*",
    "@wired/scanner": "workspace:*",
    "@wired/sync": "workspace:*",
    "@wired/ui": "workspace:*",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0"
}
